# RecallAI Configuration
# Copy this to .env and fill in your values

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=recallai
POSTGRES_PASSWORD=recallai_dev
POSTGRES_DB=recallai

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# API Keys (needed in later phases)
# Phase 3+: OpenAI Whisper API
OPENAI_API_KEY=

# Phase 4+: Google Cloud / Vertex AI for Multimodal Embeddings
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Phase 5+: Anthropic Claude API
ANTHROPIC_API_KEY=

# Server
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=true

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=500
